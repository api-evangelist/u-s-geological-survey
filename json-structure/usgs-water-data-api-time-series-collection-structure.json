{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/u-s-geological-survey/refs/heads/main/json-structure/usgs-water-data-api-time-series-collection-structure.json",
  "description": "Collection of USGS water data time series observations.",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "description": "GeoJSON type.",
      "example": "FeatureCollection"
    },
    "features": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/TimeSeriesFeature"
      }
    },
    "numberMatched": {
      "type": "int32",
      "description": "Total number of matching observations.",
      "example": 8760
    },
    "numberReturned": {
      "type": "int32",
      "description": "Number of observations returned.",
      "example": 100
    }
  },
  "name": "TimeSeriesCollection"
}